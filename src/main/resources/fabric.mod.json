{
	"schemaVersion": 1,
	"id": "ohmylist",
	"version": "${version}",
	"name": "OhMyList",
	"description": "A client-side utility mod for quality-of-life tweaks.",
	"authors": [
		"Fenad2"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/Fenad2/OhMyList"
	},
	"license": "LGPL-3.0",
	"icon": "assets/ohmylist/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"com.ohmylist.OhMyList"
		],
		"modmenu": [
			"com.ohmylist.OhMyListModMenuApiImpl"
		]
	},
	"mixins": [
		"ohmylist.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": "*",
		"malilib": "*"
	},
	"custom": {
		"modmenu:clientsideOnly": true
	}
}
